{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/ask", "dest": "/api/index.py" },
    { "src": "/feedback", "dest": "/api/index.py" },
    { "src": "/feedback/summary", "dest": "/api/index.py" },
    { "src": "/monitor", "dest": "/api/index.py" },
    { "src": "/metrics", "dest": "/api/index.py" },
    { "src": "/docs", "dest": "/api/index.py" },
    { "src": "/openapi.json", "dest": "/api/index.py" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/index.py": { "maxDuration": 60 }
  }
}
